{
  "version": 2,
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/dashboard", "destination": "/dashboard.html" },
    { "source": "/app", "destination": "/dashboard.html" },
    { "source": "/marketplace", "destination": "/dashboard.html" },
    { "source": "/proofbook", "destination": "/dashboard.html" },
    { "source": "/wallet", "destination": "/dashboard.html" },
    { "source": "/((?!api|assets|favicon.ico|robots.txt|manifest.webmanifest).*)", "destination": "/index.html" }
  ]
}
