APP_ENV=production
APP_BASE_URL=http://localhost:8000
ALLOWED_HOSTS=localhost,127.0.0.1,.replit.app,.replit.dev
DB_PATH=./data/membra.db
UPLOAD_DIR=./static/uploads
MAX_UPLOAD_MB=12
RATE_LIMIT_REQUESTS=120
RATE_LIMIT_WINDOW_SECONDS=60

# Prefer ADMIN_TOKEN_SHA256 in production. Generate with:
# python -c "import hashlib; print(hashlib.sha256(b'your-strong-token').hexdigest())"
ADMIN_TOKEN=change-me
ADMIN_TOKEN_SHA256=

# Optional live LLM providers. App works without these using deterministic rules.
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Optional Stripe hooks. App works without Stripe and returns "Stripe not configured."
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=
