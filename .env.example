APP_BASE_URL=http://localhost:8000
DB_PATH=./data/membra.db
UPLOAD_DIR=./static/uploads
ADMIN_TOKEN=replace-with-long-random-token

# Optional live LLM providers. App works without these using deterministic rules.
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Optional Stripe hooks. App works without Stripe and returns "Stripe not configured."
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=
