run = "python scripts/apply_migrations.py && uvicorn app:app --host 0.0.0.0 --port 8000"
entrypoint = "app.py"
modules = ["python-3.11"]

[nix]
channel = "stable-24_05"

[deployment]
run = ["sh", "-c", "python scripts/apply_migrations.py && uvicorn app:app --host 0.0.0.0 --port 8000"]
deploymentTarget = "cloudrun"

[[ports]]
localPort = 8000
externalPort = 80
